iew+json":{"version_major":2,"version_minor":0,"model_id":"36cc78d83e26496da1a81dd277ae1170"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["generation_config.json:   0%|          | 0.00/136 [00:00<?, ?B/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"51e7846c4c7d455ab6c4ea4de59b712a"}},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Loaded v5 checkpoint\n"]}]},{"cell_type":"code","source":["def get_candidate_token_ids(tokenizer):\n","    cids = {}\n","    for letter in CHOICE_LETTERS:\n","        forms = [letter, \" \"+letter, \"\\n\"+letter, letter+\".\", \" \"+letter+\".\"]\n","        ids = set()\n","        for f in forms:\n","            enc = tokenizer.encode(f, add_special_tokens=False)\n","            if enc: ids.add(enc[-1])\n","        cids[letter] = sorted(ids)\n","    return cids\n","\n","candidate_ids = get_candidate_token_ids(processor.tokenizer)\n","\n","def predict_batch_logprob(df_batch):\n","    images = [load_image(row) for _, row in df_batch.iterrows()]\n","    prompts = [build_prompt(row) for _, row in df_batch.iterrows()]\n","    inputs = processor(text=prompts, images=images, return_tensors=\"pt\", padding=True)\n","    inputs = {k: v.to(model.device) if torch.is_tensor(v) else v for k, v in inputs.items()}\n","    with torch.inference_mode():\n","        logits = model(**inputs).logits[:, -1, :]\n","    log_probs = torch.log_softmax(logits, dim=-1)\n","    preds = []\n","    for i, (_, row) in enumerate(df_batch.iterrows()):\n","        scores = [log_probs[i, candidate_ids[CHOICE_LETTERS[ci]]].max().item()\n","                  for ci in range(len(row[\"choices\"]))]\n","        preds.append(int(np.argmax(scores)))\n","    return preds\n","\n","def predict_batch_generate(df_batch):\n","    images = [load_image(row) for _, row in df_batch.iterrows()]\n","    prompts = [build_prompt(row) for _, row in df_batch.iterrows()]\n","    inputs = processor(text=prompts, images=images, return_tensors=\"pt\", padding=True)\n","    inputs = {k: v.to(model.device) if torch.is_tensor(v) else v for k, v in inputs.items()}\n","    with torch.inference_mode():\n","        outputs = model.generate(**inputs, max_new_tokens=20, do_sample=False)\n","    input_len = inputs[\"input_ids\"].shape[1]\n","    preds = []\n","    for i, (_, row) in enumerate(df_batch.iterrows()):\n","        generated = processor.tokenizer.decode(outputs[i, input_len:], skip_special_tokens=True).strip()\n","        letter = generated[0] if generated and generated[0] in CHOICE_LETTERS else None\n","        if letter and letter in CHOICE_LETTERS[:len(row[\"choices\"])]:\n","            preds.append(CHOICE_LETTERS.index(letter))\n","        else:\n","            preds.append(0)\n","    return preds\n","\n","# Run both on same 200 samples\n","eval_df = val_df.sample(n=200, random_state=SEED).reset_index(drop=True)\n","\n","logprob_preds, gen_preds = [], []\n","for start in tqdm(range(0, len(eval_df), BATCH_SIZE_INFER), desc=\"Log-prob\"):\n","    batch = eval_df.iloc[start:start+BATCH_SIZE_INFER]\n","    logprob_preds.extend(predict_batch_logprob(batch))\n","    torch.cuda.empty_cache()\n","\n","for start in tqdm(range(0, len(eval_df), BATCH_SIZE_INFER), desc=\"Generate\"):\n","    batch = eval_df.iloc[start:start+BATCH_SIZE_INFER]\n","    gen_preds.extend(predict_batch_generate(batch))\n","    torch.cuda.empty_cache()\n","\n","eval_df[\"lp\"] = logprob_preds\n","eval_df[\"gen\"] = gen_preds\n","lp_acc = (eval_df[\"lp\"] == eval_df[\"answer\"]).mean()\n","gen_acc = (eval_df[\"gen\"] == eval_df[\"answer\"]).mean()\n","\n","print(f\"\\nLog-prob:    {lp_acc:.4f}\")\n","print(f\"Generation:  {gen_acc:.4f}\")\n","\n","if gen_acc > lp_acc + 0.01:\n","    print(\"→ Generation is better! Submit with generation.\")\n","elif lp_acc > gen_acc + 0.01:\n","    print(\"→ Log-prob is better. Stick with it.\")\n","else:\n","    print(\"→ Same accuracy. Inference method isn't the bottleneck.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":152,"referenced_widgets":["2c6106e8697541528b702054102e44e9","287d7e5749cb4a1c9c479c7c36778aa0","135809d9ea8344718200b774aeebc1ac","d571fb3fe03144198335a69290217aa1","c23818ba5f0a497c84e8ca79652cc5ab","b002166fc4704a3ab0658b2ffeb210c0","79cbf8f616f64beb896539044d989d82","f09fa098c926482ba123e35108f45411","0145c4f4626d49128737b7060017beb9","7ed9d1cd4fd54c8d827ee2fb8ee72793","d77bd01c0ea741ad925872f08c86acf6","901d73993adc4513af9bdf643e7ad299","e899dcafe00543e6a82a981eef4ed52d","381c88e3b8bf4966904d0f4bc3ad646a","a71c06f945c74f228bdb46db15282476","ddabe5d897a64f9695483fa543e9d2e7","7904f351c6564448af15c4b6e20a72f6","6099f1c3f81c4cf88e490fa727654e12","89697ee9c60b4dd2b9d4f51105032098","01fdd8c4d1fb4f6caff558438791730b","ec3e54a4dd854322ba50662b71dc93f8","28b3fdf1455d4b4891d7e8781abc04aa"]},"id":"FcV4zA42-RFS","executionInfo":{"status":"ok","timestamp":1777395554314,"user_tz":240,"elapsed":731618,"user":{"displayName":"Ananya Shashidhara Nadig","userId":"09952178172431067268"}},"outputId":"abb97e82-7d53-404d-e35a-ea99ede3436f"},"execution_count":8,"outputs":[{"output_type":"display_data","data":{"text/plain":["Log-prob:   0%|          | 0/50 [00:00<?, ?it/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"2c6106e8697541528b702054102e44e9"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["Generate:   0%|          | 0/50 [00:00<?, ?it/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"901d73993adc4513af9bdf643e7ad299"}},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","Log-prob:    0.6550\n","Generation:  0.6600\n","→ Same accuracy. Inference method isn't the bottleneck.\n"]}]},{"cell_type":"code","source":["USE_GEN = gen_acc > lp_acc\n","print(f\"Using: {'Generation' if USE_GEN else 'Log-prob'}\")\n","\n","all_preds = []\n","for start in tqdm(range(0, len(test_df), BATCH_SIZE_INFER), desc=\"Test\"):\n","    batch = test_df.iloc[start:start+BATCH_SIZE_INFER]\n","    if USE_GEN:\n","        all_preds.extend(predict_batch_generate(batch))\n","    else:\n","        all_preds.extend(predict_batch_logprob(batch))\n","    torch.cuda.empty_cache()\n","\n","submission = pd.DataFrame({\"id\": test_df[\"id\"], \"answer\": all_preds})\n","submission.to_csv(\"/content/submission.csv\", index=False)\n","submission.to_csv(\"/content/drive/MyDrive/submission_v5_gen.csv\", index=False)\n","\n","from google.colab import files\n","files.download(\"/content/submission.csv\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":67,"referenced_widgets":["2a72063a8b1c4ae1bf1479a2cd93d350","45a49fe5a9fe4d208a58614a2e754cbf","84d17922baff4331aeebf24f8b5e3587","1db0a82e2452441db53a6bb8139eec93","78d4bccbce474858a819505bc99ba6e9","79aaa8c498cb4471a51012c1a2e02773","6e087572f17341cb9d24a94cc3ff5a35","46827ee5b6fa432fb1650931c3f9a643","2a21e731276c454390fcd3576422d8f5","c652e06766824ce792f692295aeb8b98","13b26b9ce1814748865a59ef45460616"]},"id":"ArEPCPjc-TZN","executionInfo":{"status":"ok","timestamp":1777397647300,"user_tz":240,"elapsed":2037748,"user":{"displayName":"Ananya Shashidhara Nadig","userId":"09952178172431067268"}},"outputId":"de336ef1-a31d-4d06-9ab6-8e2de46bfc99"},"execution_count":9,"outputs":[{"output_type":"stream","name":"stdout","text":["Using: Generation\n"]},{"output_type":"display_data","data":{"text/plain":["Test:   0%|          | 0/252 [00:00<?, ?it/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"2a72063a8b1c4ae1bf1479a2cd93d350"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["\n","    async function download(id, filename, size) {\n","      if (!google.colab.kernel.accessAllowed) {\n","        return;\n","      }\n","      const div = document.createElement('div');\n","      const label = document.createElement('label');\n","      label.textContent = `Downloading \"${filename}\": `;\n","      div.appendChild(label);\n","      const progress = document.createElement('progress');\n","      progress.max = size;\n","      div.appendChild(progress);\n","      document.body.appendChild(div);\n","\n","      const buffers = [];\n","      let downloaded = 0;\n","\n","      const channel = await google.colab.kernel.comms.open(id);\n","      // Send a message to notify the kernel that we're ready.\n","      channel.send({})\n","\n","      for await (const message of channel.messages) {\n","        // Send a message to notify the kernel that we're ready.\n","        channel.send({})\n","        if (message.buffers) {\n","          for (const buffer of message.buffers) {\n","            buffers.push(buffer);\n","            downloaded += buffer.byteLength;\n","            progress.value = downloaded;\n","          }\n","        }\n","      }\n","      const blob = new Blob(buffers, {type: 'application/binary'});\n","      const a = document.createElement('a');\n","      a.href = window.URL.createObjectURL(blob);\n","      a.download = filename;\n","      div.appendChild(a);\n","      a.click();\n","      div.remove();\n","    }\n","  "]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["download(\"download_c0adb862-698c-41a5-bbba-18e36f386421\", \"submission.csv\", 13114)"]},"metadata":{}}]},{"cell_type":"markdown","source":["## **New inference method: full-sequence log-likelihood scoring**\n","\n","Instead of just checking the letter probability at position -1, we score the entire answer phrase for each choice.\n","\n","The idea: for each choice, append \"A. [choice text]\" to the prompt, run the full sequence through the model, and sum the log-probabilities of all answer tokens. The choice with the highest total probability wins.\n","\n","This aligns perfectly with how the model was trained (on the full answer phrase), unlike letter-only scoring which only checks one position."],"metadata":{"id":"-fhfN7AZEFUL"}},{"cell_type":"code","source":["def predict_batch_full_loglik(df_batch):\n","    \"\"\"Score each choice by full answer log-likelihood, batched.\"\"\"\n","    preds = []\n","\n","    for _, row in df_batch.iterrows():\n","        image = load_image(row)\n","        prompt_text = build_prompt(row, include_answer=False)\n","        n_choices = len(row[\"choices\"])\n","\n","        # Build all choice sequences\n","        all_texts = []\n","        all_images = []\n","        answer_lengths = []\n","\n","        for ci in range(n_choices):\n","            letter = CHOICE_LETTERS[ci]\n","            answer_str = f\" {letter}. {row['choices'][ci]}\"\n","            full_text = prompt_text + answer_str\n","            all_texts.append(full_text)\n","            all_images.append(image)\n","            answer_lengths.append(len(processor.tokenizer.encode(answer_str, add_special_tokens=False)))\n","\n","        # Process all choices at once\n","        inputs = processor(text=all_texts, images=all_images, return_tensors=\"pt\", padding=True, truncation=False)\n","        inputs = {k: v.to(model.device) if torch.is_tensor(v) else v for k, v in inputs.items()}\n","\n","        with torch.inference_mode():\n","            logits = model(**inputs).logits\n","\n","        log_probs = torch.log_softmax(logits, dim=-1)\n","\n","        scores = []\n","        for ci in range(n_choices):\n","            seq_len = inputs[\"attention_mask\"][ci].sum().item()\n","            n_answer = answer_lengths[ci]\n","            total = 0.0\n","            for t in range(n_answer):\n","                pos = seq_len - n_answer + t - 1\n","                token_id = inputs[\"input_ids\"][ci, seq_len - n_answer + t].item()\n","                total += log_probs[ci, pos, token_id].item()\n","            scores.append(total / n_answer)\n","\n","        preds.append(int(np.argmax(scores)))\n","\n","    return preds\n","\n","# Test on 200 samples\n","eval_df = val_df.sample(n=200, random_state=SEED).reset_index(drop=True)\n","\n","full_preds = []\n","for start in tqdm(range(0, len(eval_df), BATCH_SIZE_INFER), desc=\"Full-loglik\"):\n","    batch = eval_df.iloc[start:start+BATCH_SIZE_INFER]\n","    p = predict_batch_full_loglik(batch)\n","    full_preds.extend(p)\n","    torch.cuda.empty_cache()\n","\n","full_acc = (eval_df[\"full_pred\"] if \"full_pred\" in eval_df else pd.Series(full_preds) == eval_df[\"answer\"]).mean()\n","eval_df[\"full_pred\"] = full_preds\n","full_acc = (eval_df[\"full_pred\"] == eval_df[\"answer\"]).mean()\n","\n","print(f\"\\nLog-prob (letter):     0.6550\")\n","print(f\"Generation:            0.6600\")\n","print(f\"Full log-likelihood:   {full_acc:.4f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":120,"referenced_widgets":["f6de71a43824477e987571175c88ff3f","83c7a32a534149bd9b4606744a96fc13","cb3ea8c990cd4fb39937350f45eff6f1","33c2b22bc1b84849ae088fe792f0a4c3","01f6e4dcd0dd4ea4a6e8c65978465f12","51ac650197f24635a1c1e81bbb507d44","5bc1fca420234e3187e099656546df10","884b8c63f63e4e4f93fcdf385b09dc78","4a108a964fc44447ab596f3ab8df01fe","c5bd830652a947a59ce0a409b47eed80","427c31aff06048fb98d253aadad191f1"]},"id":"73O_EYthCK4T","executionInfo":{"status":"ok","timestamp":1777398638089,"user_tz":240,"elapsed":990753,"user":{"displayName":"Ananya Shashidhara Nadig","userId":"09952178172431067268"}},"outputId":"50df4665-22c4-436f-e7ba-3e3c4d011bbd"},"execution_count":10,"outputs":[{"output_type":"display_data","data":{"text/plain":["Full-loglik:   0%|          | 0/50 [00:00<?, ?it/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"f6de71a43824477e987571175c88ff3f"}},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","Log-prob (letter):     0.6550\n","Generation:            0.6600\n","Full log-likelihood: 